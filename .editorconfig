root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.swift]
indent_size = 4

[*.sh]
indent_size = 4

[*.{json,yml,yaml,md}]
indent_size = 2

[*.{plist,xml,pbxproj,xcscheme}]
indent_style = tab
trim_trailing_whitespace = true
